# Central env template for this monorepo
# Copy only the needed section into:
# - backend/.env
# - client/.env

# =========================
# Backend (backend/.env)
# =========================
PORT=3000
MONGO_URL=mongodb://127.0.0.1:27017/pinterest_clone
CLIENT_URL=http://localhost:5173,https://petrikba.github.io

# =========================
# Client (client/.env)
# =========================
VITE_API_ENDPOINT=http://localhost:3000
VITE_URL_IK_ENDPOINT=https://ik.imagekit.io/your_imagekit_id
